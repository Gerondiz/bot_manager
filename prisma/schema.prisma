// Prisma schema для bot_manager
// ВАЖНО: ID тип — TEXT (не UUID), т.к. таблицы созданы через init-db.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bot {
  id            String   @id
  name          String
  type          BotType
  token         String   @db.Text
  tokenEncrypted Boolean  @default(true)
  enabled       Boolean  @default(true)
  status        String   @default("unknown")
  lastChecked   DateTime? @map("lastChecked")
  lastError     String?  @db.Text @map("lastError")
  createdAt     DateTime @default(now()) @map("createdAt")
  updatedAt     DateTime @updatedAt @map("updatedAt")

  tgWebhookUrl     String?  @map("tgWebhookUrl")
  tgAllowGroups    Boolean  @default(false) @map("tgAllowGroups")
  tgAllowedGroups  String[] @default([]) @map("tgAllowedGroups")

  aliceSkillId     String?  @map("aliceSkillId")
  aliceOauthToken  String?  @db.Text @map("aliceOauthToken")

  webhookUrl       String?  @map("webhookUrl")
  webhookSecret    String?  @map("webhookSecret")

  messages         Message[]
  logs             BotLog[]
  chats            BotChat[]
  healthChecks     HealthCheck[]

  @@map("bots")
}

model Message {
  id            String    @id
  botId         String    @map("botId")
  chatId        String    @map("chatId")
  userId        String    @map("userId")
  username      String?
  firstName     String?   @map("firstName")
  direction     Direction
  text          String?   @db.Text
  photoFileId   String?   @map("photoFileId")
  documentFileId String?  @map("documentFileId")
  messageId     Int?      @map("messageId")
  replyToMsgId  Int?      @map("replyToMsgId")
  timestamp     DateTime  @default(now())

  bot           Bot       @relation(fields: [botId], references: [id])

  @@map("messages")
  @@index([botId, timestamp])
  @@index([botId, chatId, timestamp])
}

model BotChat {
  id          String   @id
  botId       String   @map("botId")
  chatId      String   @map("chatId")
  title       String?
  type        String
  username    String?
  firstName   String?  @map("firstName")
  lastName    String?  @map("lastName")
  memberCount Int?     @map("memberCount")
  firstSeen   DateTime @default(now()) @map("firstSeen")
  lastSeen    DateTime @default(now()) @map("lastSeen")

  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chatId])
  @@index([botId, lastSeen])
  @@map("bot_chats")
}

model HealthCheck {
  id        String   @id
  botId     String   @map("botId")
  healthy   Boolean
  status    String
  error     String?  @db.Text
  checkedAt DateTime @default(now()) @map("checkedAt")

  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, checkedAt])
  @@map("health_checks")
}

model BotLog {
  id        String   @id
  botId     String?  @map("botId")
  level     LogLevel
  message   String   @db.Text
  context   Json?
  timestamp DateTime @default(now())

  bot       Bot?     @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@map("bot_logs")
  @@index([botId, timestamp])
}

model ApiKey {
  id          String   @id
  name        String
  keyHash     String   @unique
  permissions String[] @default([])
  createdAt   DateTime @default(now()) @map("createdAt")
  lastUsedAt  DateTime? @map("lastUsedAt")

  @@map("api_keys")
}

enum BotType {
  TELEGRAM
  ALICE
}

enum Direction {
  INCOMING
  OUTGOING
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}
