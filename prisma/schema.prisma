// Prisma schema для bot_manager

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bot {
  id            String   @id @default(uuid())
  name          String
  type          BotType
  token         String   @db.Text
  tokenEncrypted Boolean  @default(true)
  enabled       Boolean  @default(true)
  status        String   @default("unknown")
  lastChecked   DateTime?
  lastError     String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Настройки Telegram
  tgWebhookUrl     String?
  tgAllowGroups    Boolean  @default(false)
  tgAllowedGroups  String[] @default([])

  // Настройки Alice
  aliceSkillId     String?
  aliceOauthToken  String?  @db.Text

  // Интеграции
  webhookUrl       String?
  webhookSecret    String?

  messages         Message[]
  logs             BotLog[]
  chats            BotChat[]
  healthChecks     HealthCheck[]

  @@map("bots")
}

model Message {
  id            String    @id @default(uuid())
  botId         String
  chatId        String
  userId        String
  username      String?
  firstName     String?
  direction     Direction
  text          String?   @db.Text
  photoFileId   String?
  documentFileId String?
  messageId     Int?      // Telegram message ID
  replyToMsgId  Int?
  timestamp     DateTime  @default(now())

  bot           Bot       @relation(fields: [botId], references: [id])

  @@map("messages")
  @@index([botId, timestamp])
  @@index([botId, chatId, timestamp])
}

model BotChat {
  id          String   @id @default(uuid())
  botId       String
  chatId      String   // Telegram chat ID (negative for groups)
  title       String?
  type        String   // private, group, supergroup, channel
  username    String?
  firstName   String?
  lastName    String?
  memberCount Int?
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, chatId])
  @@index([botId, lastSeen])
  @@map("bot_chats")
}

model HealthCheck {
  id        String   @id @default(uuid())
  botId     String
  healthy   Boolean
  status    String   // online, error
  error     String?  @db.Text
  checkedAt DateTime @default(now())

  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, checkedAt])
  @@map("health_checks")
}

model BotLog {
  id        String   @id @default(uuid())
  botId     String?  // Nullable для системных логов
  level     LogLevel
  message   String   @db.Text
  context   Json?
  timestamp DateTime @default(now())

  bot       Bot?     @relation(fields: [botId], references: [id], onDelete: SetNull)

  @@map("bot_logs")
  @@index([botId, timestamp])
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String   @unique
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?

  @@map("api_keys")
}

enum BotType {
  TELEGRAM
  ALICE
}

enum Direction {
  INCOMING
  OUTGOING
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}
