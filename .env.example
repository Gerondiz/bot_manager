# Database — PostgreSQL (обязательно для production)
# Dev: можно использовать Docker PostgreSQL или Vercel Postgres
# Prod: Vercel Postgres (автоматически создаётся при деплое)
DATABASE_URL="postgresql://user:password@localhost:5432/bot_manager"

# Encryption (32-byte hex для AES-256-GCM)
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-key-here-00000000"

# Admin Auth
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme-me-123
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# AAF Integration
AAF_WEBHOOK_URL="http://localhost:8000/webhook"
AAF_WEBHOOK_SECRET="shared-webhook-secret"

# Webhook Base URL — внешний URL для Telegram webhook
# Для Vercel: не требуется (определяется автоматически)
# Для локальной разработки: укажите URL, по которому Telegram может достучаться
# WEBHOOK_BASE_URL="https://your-unique-ngrok-url.ngrok-free.app"
